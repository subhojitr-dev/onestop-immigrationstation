# ============================================================
# One Stop Immigration Station — Environment Variables
# ============================================================
# COPY this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub (already in .gitignore)
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to frontend, server only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=One Stop Immigration Station

# ── Email (SendGrid) ─────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-key-here
SENDGRID_FROM_EMAIL=admin@mylegalimigrationservices.com

# ── Expo (mobile) ────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
